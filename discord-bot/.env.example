# Discord Bot Configuration

# Discord credentials (required)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=                    # Optional: for testing in a specific server

# RAG Backend connection (required)
RAG_API_URL=http://localhost:3001/api
RAG_API_KEY=your_api_key_from_settings

# Bot customization
BOT_NAME=Docs Bot                    # Name shown in embeds
BOT_COMMAND_PREFIX=!docs             # Prefix for message commands
BOT_EMBED_COLOR=0x7c3aed             # Hex color for embeds

# Forum mode settings
FORUM_MODE=true                      # Treat knowledge base as forum discussions
BOT_PERSONALITY=casual               # casual, formal, friendly
MAX_IMAGES_PER_RESPONSE=4            # Max images to show per response
MAX_DOC_UPLOAD_MB=15                 # Max upload size for /adddoc and /convertdoc
ATTACHMENT_DOWNLOAD_TIMEOUT_MS=10000 # Timeout for downloading Discord attachments
INSTRUCTION_PARSE_TIMEOUT_MS=8000    # Timeout for instruction parser LLM fallback

# Rate limiting
COOLDOWN_SECONDS=5                   # Seconds between commands per user

# Logging
LOG_LEVEL=info                       # debug, info, warn, error
